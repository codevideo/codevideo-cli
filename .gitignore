# .env
.env

# needed for grimoire, otherwise it won't ignore the node_modules directory becaus our real .gitignore is in the root
node_modules

# nohup
nohup.out

# mp4s generated in CLI mode
*.mp4

# macOS DS_Store
.DS_Store

# log files
*.log

# chrome versions in puppeteer-runner
puppeteer-runner/chrome

# generated npm release artifacts
npm/node_modules
npm/dist
npm/packages/codevideo-cli-*/bin/codevideo-cli*
npm/packages/codevideo-cli/runtime/recordVideoV3.js
npm/packages/codevideo-cli/runtime/runtimePaths.js
npm/packages/*/LICENSE
